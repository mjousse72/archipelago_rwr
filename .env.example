# Path to your Running with Rifles installation directory
# Used by tests to verify weapon files exist on disk
# Example: E:\SteamLibrary\steamapps\common\RunningWithRifles
RWR_GAME_PATH=

# Path to the archipelago_rwr project root (where rwr_mod/ lives)
# Used by tests to verify mod files match the Python APWorld data
# Example: c:\Users\you\archipelago_rwr
RWR_PROJECT_PATH=
